#!/usr/bin/env python3
"""ssh-debug-proxmox - Proxmox VE host debugging helper (AI-optimized JSON output)

Usage:
  ssh-debug-proxmox <host> status                    # Host health, memory, CPU, uptime
  ssh-debug-proxmox <host> vms                       # All VMs with allocated vs actual memory
  ssh-debug-proxmox <host> vm <vmid>                 # Single VM config + status (via qm)
  ssh-debug-proxmox <host> storage                   # Storage pools and usage
  ssh-debug-proxmox <host> cluster                   # Cluster status and node list
  ssh-debug-proxmox <host> dmesg [-n N]              # Kernel warnings/errors
  ssh-debug-proxmox <host> disk [path]               # Filesystem usage
  ssh-debug-proxmox <host> logs [service] [-n N]     # Service logs (pvedaemon, pveproxy, etc.)

All commands are READ-ONLY. No modifications are made to target hosts.
Host is always the first argument (for Claude Code permission matching).
"""

import json
import posixpath
import re
import subprocess
import sys

SSH_TIMEOUT = 30
MAX_FIELD_BYTES = 200000

HOST_RE = re.compile(r'^[a-z0-9][a-z0-9.-]+$', re.ASCII)

ALLOWED_DU_PATHS = [
    '/var/lib/vz',
    '/var/lib/pve',
    '/var/log',
    '/var/log/pve',
    '/tmp',
    '/etc/pve',
]

LOG_SERVICES = [
    'pvedaemon', 'pveproxy', 'pvestatd', 'pve-cluster',
    'pve-ha-lrm', 'pve-ha-crm', 'pve-firewall',
    'corosync', 'ceph-mon', 'ceph-osd',
]

COMMANDS = {}


def _error(msg):
    print(json.dumps({"error": msg}, indent=2))
    sys.exit(1)


def _usage():
    _error("Usage: ssh-debug-proxmox <host> <command> [args]\n"
           f"Commands: {', '.join(sorted(COMMANDS))}")


def _validate_host(host):
    if not HOST_RE.fullmatch(host):
        _error(f"Invalid hostname: {host}. Must match [a-z0-9][a-z0-9.-]+")


def _validate_du_path(path):
    if not path.startswith('/'):
        _error(f"Path must be absolute: {path}")
    normalized = posixpath.normpath(path)
    if '..' in normalized.split('/'):
        _error(f"Path traversal not allowed: {path}")
    for allowed in ALLOWED_DU_PATHS:
        if normalized == allowed or normalized.startswith(allowed + '/'):
            return
    _error(f"Path not allowed for du: {normalized}. Allowed: {', '.join(ALLOWED_DU_PATHS)}")


def _ssh(host, cmd_args, timeout=SSH_TIMEOUT):
    full_cmd = [
        'ssh', '-o', 'ConnectTimeout=10', '-o', 'StrictHostKeyChecking=accept-new',
        host,
    ] + cmd_args
    result = subprocess.run(
        full_cmd, capture_output=True, text=True, errors='replace', timeout=timeout,
    )
    return result.stdout, result.stderr, result.returncode


def _ssh_or_error(host, cmd_args, label="command", timeout=SSH_TIMEOUT):
    stdout, stderr, rc = _ssh(host, cmd_args, timeout)
    if rc != 0:
        return {"error": f"{label} failed (rc={rc}): {stderr.strip()[:500]}"}
    text = stdout.strip()
    if len(text) > MAX_FIELD_BYTES:
        return text[:MAX_FIELD_BYTES] + "\n... [truncated]"
    return text


def _ssh_json(host, cmd_args, label="command", timeout=SSH_TIMEOUT):
    result = _ssh_or_error(host, cmd_args, label, timeout)
    if isinstance(result, dict):
        return result
    try:
        return json.loads(result)
    except json.JSONDecodeError:
        return {"raw": result[:2000]}


def _output(data):
    print(json.dumps(data, indent=2))


def _parse_int_arg(args, flag, default):
    for i, a in enumerate(args):
        if a == flag and i + 1 < len(args):
            try:
                return int(args[i + 1])
            except ValueError:
                pass
        if a.startswith(f'{flag}='):
            try:
                return int(a.split('=', 1)[1])
            except ValueError:
                pass
    return default


# --- Commands ---

def cmd_status(host, args):
    output = {"host": host, "profile": "proxmox", "command": "status"}
    output["uptime"] = _ssh_or_error(host, ['uptime'], 'uptime')
    output["memory"] = _ssh_or_error(host, ['free', '-h'], 'free')
    output["load"] = _ssh_or_error(host, ['cat', '/proc/loadavg'], 'loadavg')
    output["failed_units"] = _ssh_or_error(
        host, ['systemctl', '--failed', '--no-pager', '--no-legend'], 'systemctl --failed')
    # PVE version
    output["pve_version"] = _ssh_or_error(host, ['/usr/bin/pveversion', '-v'], 'pveversion')
    _output(output)


def _parse_kvm_line(line):
    """Parse a single ps output line for a KVM process.
    Returns a dict with vmid, name, alloc_mib, rss_mib, started, cpu_cores, cpu_type, storage_type, drives.
    Returns None if the line is not a valid KVM process."""
    parts = line.split()
    if len(parts) < 8:
        return None
    try:
        rss_kib = int(parts[1])
    except ValueError:
        return None
    # lstart is 5 fields: Day Mon DD HH:MM:SS YYYY
    started = ' '.join(parts[2:7])
    args_str = ' '.join(parts[7:])
    if '/usr/bin/kvm' not in args_str:
        return None

    m_mem = re.search(r'-m (\d+)', args_str)
    if not m_mem:
        return None
    alloc_mib = int(m_mem.group(1))
    m_name = re.search(r'-name (\S+)', args_str)
    name = m_name.group(1).split(',')[0] if m_name else ''
    m_vmid = re.search(r'-id (\d+)', args_str)
    vmid = m_vmid.group(1) if m_vmid else ''
    if not vmid:
        return None

    # CPU info
    m_smp = re.search(r'-smp (\d+)', args_str)
    cpu_cores = int(m_smp.group(1)) if m_smp else None
    m_cpu = re.search(r'-cpu (\S+)', args_str)
    cpu_type = m_cpu.group(1).split(',')[0] if m_cpu else None

    # Storage: extract drive file paths to determine storage type
    drives = re.findall(r'-drive file=([^,]+)', args_str)
    storage_type = None
    for d in drives:
        if 'cloudinit' in d:
            continue
        if '/mnt/pve/shared-ssd/' in d:
            storage_type = 'shared-ssd'
        elif '/dev/vg-crypt-' in d:
            storage_type = 'local-ssd-encrypted'
        elif '/mnt/pve/' in d:
            storage_type = d.split('/mnt/pve/')[1].split('/')[0]
        elif '/dev/' in d:
            storage_type = 'local'
        else:
            continue
        break

    return {
        "vmid": vmid,
        "name": name,
        "alloc_mib": alloc_mib,
        "rss_mib": rss_kib // 1024,
        "started": started,
        "cpu_cores": cpu_cores,
        "cpu_type": cpu_type,
        "storage": storage_type,
        "drives": drives,
    }


def _get_kvm_data(host):
    """Single SSH call to get host memory + all KVM process data. Returns (host_mem_mib, [vm_dicts])."""
    kvm_script = (
        'grep MemTotal /proc/meminfo; '
        'ps -C kvm -o pid=,rss=,lstart=,args= || true'
    )
    kvm_out = _ssh_or_error(host, [kvm_script], 'kvm process scan', timeout=30)
    if isinstance(kvm_out, dict):
        return 0, kvm_out

    lines = kvm_out.strip().split('\n')
    host_mem_mib = 0
    vms = []

    for line in lines:
        if line.startswith('MemTotal:'):
            try:
                host_mem_mib = int(line.split()[1]) // 1024
            except (ValueError, IndexError):
                pass
            continue
        vm = _parse_kvm_line(line)
        if vm:
            vms.append(vm)

    return host_mem_mib, vms


def cmd_vms(host, args):
    """List all VMs with allocated vs actual (RSS) memory from KVM processes."""
    output = {"host": host, "profile": "proxmox", "command": "vms"}

    host_mem_mib, vms = _get_kvm_data(host)
    if isinstance(vms, dict):
        output["error"] = vms
        _output(output)
        return

    total_alloc = sum(v['alloc_mib'] for v in vms)
    total_rss = sum(v['rss_mib'] for v in vms)
    vms.sort(key=lambda x: x['rss_mib'], reverse=True)

    # Compact output: omit drives list from vms listing
    for v in vms:
        del v['drives']

    output["vms"] = vms
    output["summary"] = {
        "vm_count": len(vms),
        "total_alloc_gib": round(total_alloc / 1024, 1),
        "total_rss_gib": round(total_rss / 1024, 1),
        "host_mem_gib": round(host_mem_mib / 1024, 1),
        "overcommit_gib": round((total_alloc - host_mem_mib) / 1024, 1) if host_mem_mib > 0 else None,
    }
    _output(output)


def cmd_vm(host, args):
    """Get details for a single VM by VMID via qm."""
    if not args:
        _error("Usage: ssh-debug-proxmox <host> vm <vmid>")
    vmid = args[0]
    if not vmid.isdigit():
        _error(f"Invalid VMID: {vmid}. Must be numeric.")
    output = {"host": host, "profile": "proxmox", "command": "vm", "vmid": vmid}
    output["config"] = _ssh_or_error(host, ['sudo', '-n', '/usr/sbin/qm', 'config', vmid], f'qm config {vmid}')
    output["status"] = _ssh_or_error(host, ['sudo', '-n', '/usr/sbin/qm', 'status', vmid, '--verbose'], f'qm status {vmid}')
    _output(output)


def cmd_storage(host, args):
    output = {"host": host, "profile": "proxmox", "command": "storage"}
    output["pools"] = _ssh_or_error(host, ['/usr/sbin/pvesm', 'status'], 'pvesm status')
    df_out = _ssh_or_error(host, ['df', '-h'], 'df')
    if isinstance(df_out, dict):
        output["df"] = df_out
    else:
        entries = []
        for line in df_out.strip().split('\n')[1:]:
            parts = line.split()
            if len(parts) >= 6:
                entries.append({
                    "filesystem": parts[0],
                    "size": parts[1],
                    "used": parts[2],
                    "avail": parts[3],
                    "use_pct": parts[4],
                    "mounted_on": parts[5],
                })
        output["df"] = entries
    _output(output)


def cmd_cluster(host, args):
    output = {"host": host, "profile": "proxmox", "command": "cluster"}
    output["status"] = _ssh_or_error(host, ['/usr/bin/pvecm', 'status'], 'pvecm status')
    output["nodes"] = _ssh_or_error(host, ['/usr/bin/pvecm', 'nodes'], 'pvecm nodes')
    _output(output)


def cmd_dmesg(host, args):
    lines = _parse_int_arg(args, '-n', 50)
    output = {"host": host, "profile": "proxmox", "command": "dmesg"}
    result = _ssh_or_error(
        host,
        ['sudo', '-n', 'dmesg', '--level=err,warn', '-T', '--nopager'],
        'dmesg',
    )
    if isinstance(result, dict):
        output["error"] = result.get("error", "")
    else:
        all_lines = result.strip().split('\n')
        output["total_lines"] = len(all_lines)
        output["output"] = '\n'.join(all_lines[-lines:])
    _output(output)


def cmd_disk(host, args):
    output = {"host": host, "profile": "proxmox", "command": "disk"}

    df_out = _ssh_or_error(host, ['df', '-h', '/'], 'df')
    if isinstance(df_out, dict):
        output["df"] = df_out
    else:
        lines = df_out.strip().split('\n')
        if len(lines) >= 2:
            parts = lines[1].split()
            output["df"] = {
                "filesystem": parts[0] if len(parts) > 0 else "",
                "size": parts[1] if len(parts) > 1 else "",
                "used": parts[2] if len(parts) > 2 else "",
                "avail": parts[3] if len(parts) > 3 else "",
                "use_pct": parts[4] if len(parts) > 4 else "",
            }

    path = args[0] if args else None
    if path:
        _validate_du_path(path)
        du_out = _ssh_or_error(host, ['sudo', '-n', 'du', '-sh', path], f'du {path}')
        if isinstance(du_out, dict):
            output["du"] = du_out
        else:
            output["du"] = {"path": path, "size": du_out.split()[0] if du_out else ""}
    else:
        du_out = _ssh_or_error(
            host,
            ['sudo', '-n', 'du', '-sh', '/var/log', '/tmp'],
            'du /var/log /tmp',
        )
        if isinstance(du_out, dict):
            output["du"] = du_out
        else:
            results = []
            for line in du_out.strip().split('\n'):
                p = line.split('\t', 1)
                if len(p) == 2:
                    results.append({"path": p[1].strip(), "size": p[0].strip()})
            output["du"] = results

    _output(output)


def cmd_logs(host, args):
    if args and args[0] not in LOG_SERVICES and not args[0].startswith('-'):
        _error(f"Unknown service: {args[0]}. Allowed: {', '.join(LOG_SERVICES)}")
    service = args[0] if args and args[0] in LOG_SERVICES else 'pvedaemon'
    rest = args[1:] if args and args[0] in LOG_SERVICES else args
    lines = _parse_int_arg(rest, '-n', 100)

    output = {"host": host, "profile": "proxmox", "command": "logs", "service": service, "lines": lines}
    result = _ssh_or_error(
        host,
        ['sudo', '-n', 'journalctl', '-u', service, '--no-pager', '-n', str(lines)],
        f'journalctl -u {service}',
    )
    if isinstance(result, dict):
        output["error"] = result.get("error", "")
    else:
        output["output"] = result
    _output(output)


COMMANDS = {
    'status': cmd_status,
    'vms': cmd_vms,
    'vm': cmd_vm,
    'storage': cmd_storage,
    'cluster': cmd_cluster,
    'dmesg': cmd_dmesg,
    'disk': cmd_disk,
    'logs': cmd_logs,
}


def main():
    argv = sys.argv[1:]
    if len(argv) < 2:
        _usage()

    host = argv[0]
    command = argv[1]
    remaining = argv[2:]

    _validate_host(host)

    handler = COMMANDS.get(command)
    if not handler:
        _error(f"Unknown command: {command}. Available: {', '.join(sorted(COMMANDS))}")

    try:
        handler(host, remaining)
    except subprocess.TimeoutExpired as e:
        _error(f"Command timed out after {e.timeout}s on {host}")
    except Exception as e:
        _error(str(e))


if __name__ == '__main__':
    main()
