#!/usr/bin/env python3
"""ssh-debug-ceph - Ceph cluster debugging helper (AI-optimized JSON output)

Usage:
  ssh-debug-ceph <host> health                          # ceph health detail + status
  ssh-debug-ceph <host> osd                             # osd tree + df + pool stats
  ssh-debug-ceph <host> mds [filesystem]                # MDS status + cache stats
  ssh-debug-ceph <host> mds-clients <mds-daemon>        # MDS client sessions
  ssh-debug-ceph <host> mds-ops <mds-daemon>            # MDS ops in flight
  ssh-debug-ceph <host> mds-perf <mds-daemon>           # MDS perf counters (caps, inodes)
  ssh-debug-ceph <host> mds-subtrees <mds-daemon>       # MDS subtree map
  ssh-debug-ceph <host> config <who> [key]              # ceph config get/dump
  ssh-debug-ceph <host> log [-n N]                      # ceph log last N warn
  ssh-debug-ceph <host> pg                              # PG stats + stuck PGs
  ssh-debug-ceph <host> blocklist                       # blocklisted clients
  ssh-debug-ceph <host> disk                            # df + du on mon data dirs

All commands are READ-ONLY. No modifications are made to target hosts.
Host is always the first argument (for Claude Code permission matching).
Designed to run on ceph monitor nodes.
"""

import json
import posixpath
import re
import subprocess
import sys

SSH_TIMEOUT = 30
MAX_FIELD_BYTES = 50000

HOST_RE = re.compile(r'^[a-z0-9][a-z0-9.-]+$', re.ASCII)

ALLOWED_DU_PATHS = [
    '/var/lib/ceph',
    '/var/log',
    '/var/log/ceph',
    '/tmp',
]

COMMANDS = {}


def _error(msg):
    print(json.dumps({"error": msg}, indent=2))
    sys.exit(1)


def _usage():
    _error("Usage: ssh-debug-ceph <host> <command> [args]\n"
           f"Commands: {', '.join(sorted(COMMANDS))}")


def _validate_host(host):
    if not HOST_RE.fullmatch(host):
        _error(f"Invalid hostname: {host}. Must match [a-z0-9][a-z0-9.-]+")


def _validate_du_path(path):
    if not path.startswith('/'):
        _error(f"Path must be absolute: {path}")
    normalized = posixpath.normpath(path)
    if '..' in normalized.split('/'):
        _error(f"Path traversal not allowed: {path}")
    for allowed in ALLOWED_DU_PATHS:
        if normalized == allowed or normalized.startswith(allowed + '/'):
            return
    _error(f"Path not allowed for du: {normalized}. Allowed: {', '.join(ALLOWED_DU_PATHS)}")


def _ssh(host, cmd_args, timeout=SSH_TIMEOUT):
    full_cmd = [
        'ssh', '-o', 'ConnectTimeout=10', '-o', 'StrictHostKeyChecking=accept-new',
        host,
    ] + cmd_args
    result = subprocess.run(
        full_cmd, capture_output=True, text=True, errors='replace', timeout=timeout,
    )
    return result.stdout, result.stderr, result.returncode


def _ssh_or_error(host, cmd_args, label="command", timeout=SSH_TIMEOUT):
    stdout, stderr, rc = _ssh(host, cmd_args, timeout)
    if rc != 0:
        return {"error": f"{label} failed (rc={rc}): {stderr.strip()[:500]}"}
    text = stdout.strip()
    if len(text) > MAX_FIELD_BYTES:
        return text[:MAX_FIELD_BYTES] + "\n... [truncated]"
    return text


def _ssh_json(host, cmd_args, label="command", timeout=SSH_TIMEOUT):
    """Run SSH command expecting JSON output, return parsed dict or error dict."""
    result = _ssh_or_error(host, cmd_args, label, timeout)
    if isinstance(result, dict):
        return result
    try:
        return json.loads(result)
    except json.JSONDecodeError:
        return {"raw": result[:2000]}


def _output(data):
    print(json.dumps(data, indent=2))


def _parse_int_arg(args, flag, default):
    """Parse -n or --top style int arg from remaining args list."""
    for i, a in enumerate(args):
        if a == flag and i + 1 < len(args):
            try:
                return int(args[i + 1])
            except ValueError:
                pass
        if a.startswith(f'{flag}='):
            try:
                return int(a.split('=', 1)[1])
            except ValueError:
                pass
    return default


# --- Commands ---

def cmd_health(host, args):
    output = {"host": host, "profile": "ceph", "command": "health"}
    output["status"] = _ssh_json(host, ['sudo', '-n', 'ceph', 'status', '-f', 'json'], 'ceph status')
    output["health_detail"] = _ssh_or_error(host, ['sudo', '-n', 'ceph', 'health', 'detail'], 'ceph health detail')
    _output(output)


def cmd_osd(host, args):
    output = {"host": host, "profile": "ceph", "command": "osd"}
    output["tree"] = _ssh_json(host, ['sudo', '-n', 'ceph', 'osd', 'tree', '-f', 'json'], 'ceph osd tree')
    output["df"] = _ssh_json(host, ['sudo', '-n', 'ceph', 'osd', 'df', '-f', 'json'], 'ceph osd df')
    output["pool_stats"] = _ssh_json(host, ['sudo', '-n', 'ceph', 'osd', 'pool', 'ls', 'detail', '-f', 'json'], 'ceph osd pool ls detail')
    _output(output)


def cmd_mds(host, args):
    fs_name = args[0] if args else None
    output = {"host": host, "profile": "ceph", "command": "mds"}
    output["mds_stat"] = _ssh_json(host, ['sudo', '-n', 'ceph', 'mds', 'stat', '-f', 'json'], 'ceph mds stat')
    if fs_name:
        if fs_name.startswith('-'):
            _error(f"Invalid filesystem name: {fs_name}")
        output["fs_status"] = _ssh_or_error(host, ['sudo', '-n', 'ceph', 'fs', 'status', fs_name], f'ceph fs status {fs_name}')
        output["fs_dump"] = _ssh_json(host, ['sudo', '-n', 'ceph', 'fs', 'dump', '-f', 'json'], 'ceph fs dump')
    else:
        output["fs_status"] = _ssh_or_error(host, ['sudo', '-n', 'ceph', 'fs', 'status'], 'ceph fs status')
    _output(output)


def cmd_mds_clients(host, args):
    if not args:
        _error("Usage: ssh-debug-ceph <host> mds-clients <mds-daemon> [client-id]")
    daemon = args[0]
    if daemon.startswith('-'):
        _error(f"Invalid daemon name: {daemon}")
    output = {"host": host, "profile": "ceph", "command": "mds-clients", "daemon": daemon}

    if len(args) > 1:
        client_id = args[1]
        output["client"] = _ssh_json(
            host,
            ['sudo', '-n', 'ceph', 'tell', daemon, 'client', 'ls', f'id={client_id}', '--cap-dump', '-f', 'json'],
            f'ceph tell {daemon} client ls id={client_id}',
            timeout=60,
        )
    else:
        output["sessions"] = _ssh_json(
            host,
            ['sudo', '-n', 'ceph', 'tell', daemon, 'session', 'ls', '-f', 'json'],
            f'ceph tell {daemon} session ls',
            timeout=60,
        )
    _output(output)


def cmd_mds_ops(host, args):
    if not args:
        _error("Usage: ssh-debug-ceph <host> mds-ops <mds-daemon>")
    daemon = args[0]
    if daemon.startswith('-'):
        _error(f"Invalid daemon name: {daemon}")
    output = {"host": host, "profile": "ceph", "command": "mds-ops", "daemon": daemon}
    output["ops_in_flight"] = _ssh_json(
        host,
        ['sudo', '-n', 'ceph', 'tell', daemon, 'dump_ops_in_flight', '-f', 'json'],
        f'ceph tell {daemon} dump_ops_in_flight',
    )
    _output(output)


def cmd_mds_perf(host, args):
    if not args:
        _error("Usage: ssh-debug-ceph <host> mds-perf <mds-daemon>")
    daemon = args[0]
    if daemon.startswith('-'):
        _error(f"Invalid daemon name: {daemon}")
    output = {"host": host, "profile": "ceph", "command": "mds-perf", "daemon": daemon}
    perf = _ssh_json(
        host,
        ['sudo', '-n', 'ceph', 'tell', daemon, 'perf', 'dump', '-f', 'json'],
        f'ceph tell {daemon} perf dump',
        timeout=60,
    )
    if isinstance(perf, dict) and 'error' not in perf:
        # Extract key MDS metrics for quick overview
        mds_stats = perf.get('mds', {})
        mds_mem = perf.get('mds_mem', {})
        output["summary"] = {
            "caps": mds_stats.get('caps', 0),
            "inodes_with_caps": mds_stats.get('inodes_with_caps', 0),
            "inodes": mds_mem.get('ino', 0),
            "caps_per_inode": round(mds_stats.get('caps', 0) / max(mds_mem.get('ino', 1), 1), 2),
            "subtrees": mds_stats.get('subtrees', 0),
            "request_count": mds_stats.get('request', 0),
            "reply_latency_avg": mds_stats.get('reply_latency', {}).get('avgcount', 0),
        }
        output["full_dump"] = perf
    else:
        output["perf"] = perf
    _output(output)


def cmd_mds_subtrees(host, args):
    if not args:
        _error("Usage: ssh-debug-ceph <host> mds-subtrees <mds-daemon>")
    daemon = args[0]
    if daemon.startswith('-'):
        _error(f"Invalid daemon name: {daemon}")
    output = {"host": host, "profile": "ceph", "command": "mds-subtrees", "daemon": daemon}
    output["subtrees"] = _ssh_json(
        host,
        ['sudo', '-n', 'ceph', 'tell', daemon, 'get', 'subtrees', '-f', 'json'],
        f'ceph tell {daemon} get subtrees',
    )
    _output(output)


def cmd_config(host, args):
    if not args:
        _error("Usage: ssh-debug-ceph <host> config <who> [key]")
    who = args[0]
    if who.startswith('-'):
        _error(f"Invalid config target: {who}")
    key = args[1] if len(args) > 1 else None
    output = {"host": host, "profile": "ceph", "command": "config", "who": who}

    if key:
        if key.startswith('-'):
            _error(f"Invalid config key: {key}")
        output["value"] = _ssh_or_error(
            host,
            ['sudo', '-n', 'ceph', 'config', 'get', who, key],
            f'ceph config get {who} {key}',
        )
    else:
        output["dump"] = _ssh_json(
            host,
            ['sudo', '-n', 'ceph', 'config', 'dump', '-f', 'json'],
            'ceph config dump',
        )
    _output(output)


def cmd_log(host, args):
    n = _parse_int_arg(args, '-n', 20)
    output = {"host": host, "profile": "ceph", "command": "log", "lines": n}
    output["warnings"] = _ssh_or_error(
        host,
        ['sudo', '-n', 'ceph', 'log', 'last', str(n), 'warn'],
        f'ceph log last {n} warn',
    )
    _output(output)


def cmd_pg(host, args):
    output = {"host": host, "profile": "ceph", "command": "pg"}
    output["stat"] = _ssh_json(host, ['sudo', '-n', 'ceph', 'pg', 'stat', '-f', 'json'], 'ceph pg stat')
    output["stuck"] = _ssh_json(
        host,
        ['sudo', '-n', 'ceph', 'pg', 'dump_stuck', 'unclean', '-f', 'json'],
        'ceph pg dump_stuck unclean',
    )
    _output(output)


def cmd_blocklist(host, args):
    output = {"host": host, "profile": "ceph", "command": "blocklist"}
    output["list"] = _ssh_or_error(host, ['sudo', '-n', 'ceph', 'osd', 'blocklist', 'ls'], 'ceph osd blocklist ls')
    _output(output)


def cmd_disk(host, args):
    output = {"host": host, "profile": "ceph", "command": "disk"}

    df_out = _ssh_or_error(host, ['df', '-h', '/'], 'df')
    if isinstance(df_out, dict):
        output["df"] = df_out
    else:
        lines = df_out.strip().split('\n')
        if len(lines) >= 2:
            parts = lines[1].split()
            output["df"] = {
                "filesystem": parts[0] if len(parts) > 0 else "",
                "size": parts[1] if len(parts) > 1 else "",
                "used": parts[2] if len(parts) > 2 else "",
                "avail": parts[3] if len(parts) > 3 else "",
                "use_pct": parts[4] if len(parts) > 4 else "",
            }

    path = args[0] if args else None
    if path:
        _validate_du_path(path)
        du_out = _ssh_or_error(host, ['sudo', '-n', 'du', '-sh', path], f'du {path}')
        if isinstance(du_out, dict):
            output["du"] = du_out
        else:
            output["du"] = {"path": path, "size": du_out.split()[0] if du_out else ""}
    else:
        du_out = _ssh_or_error(
            host,
            ['sudo', '-n', 'du', '-sh', '/var/lib/ceph', '/var/log/ceph'],
            'du /var/lib/ceph /var/log/ceph',
            timeout=60,
        )
        if isinstance(du_out, dict):
            output["du"] = du_out
        else:
            results = []
            for line in du_out.strip().split('\n'):
                p = line.split('\t', 1)
                if len(p) == 2:
                    results.append({"path": p[1].strip(), "size": p[0].strip()})
            output["du"] = results

    _output(output)


COMMANDS = {
    'health': cmd_health,
    'osd': cmd_osd,
    'mds': cmd_mds,
    'mds-clients': cmd_mds_clients,
    'mds-ops': cmd_mds_ops,
    'mds-perf': cmd_mds_perf,
    'mds-subtrees': cmd_mds_subtrees,
    'config': cmd_config,
    'log': cmd_log,
    'pg': cmd_pg,
    'blocklist': cmd_blocklist,
    'disk': cmd_disk,
}


def main():
    argv = sys.argv[1:]
    if len(argv) < 2:
        _usage()

    host = argv[0]
    command = argv[1]
    remaining = argv[2:]

    _validate_host(host)

    handler = COMMANDS.get(command)
    if not handler:
        _error(f"Unknown command: {command}. Available: {', '.join(sorted(COMMANDS))}")

    try:
        handler(host, remaining)
    except subprocess.TimeoutExpired as e:
        _error(f"Command timed out after {e.timeout}s on {host}")
    except Exception as e:
        _error(str(e))


if __name__ == '__main__':
    main()
