#!/usr/bin/env python3
"""prom - Prometheus query helper (AI-optimized JSON output)

Usage:
  prom "promql"                          # Instant query
  prom "promql" -r 24h                   # Range query (last 24h)
  prom "promql" --url http://IP:PORT     # Query specific instance
  prom "promql" --start 2025-12-08 --end 2025-12-10
  prom -f /tmp/query.txt                  # Query from file
  prom -f /tmp/query.txt -r 24h           # Range query from file
  prom --labels metric_name              # Show labels for metric
  prom --values label_name               # Show values for label
  prom --metrics [pattern]               # List metrics

Environment:
  PROM_URL    Prometheus URL (default: http://172.20.13.197:9090)

Output: JSON with ISO timestamps, summary stats for range queries
"""

import argparse
import json
import os
import subprocess
import sys
import re
from datetime import datetime, timezone

DEFAULT_URL = "http://172.20.13.197:9090"
PROM_URL = DEFAULT_URL  # set in main() from --url or PROM_URL env
CURL_TIMEOUT = "30"


def parse_duration(s):
    """Parse duration string to seconds (e.g., 1h, 24h, 7d, 30m)"""
    match = re.match(r'^(\d+)([smhdw])$', s.lower())
    if not match:
        raise ValueError(f"Invalid duration: {s} (use format like 1h, 24h, 7d)")
    n, unit = int(match.group(1)), match.group(2)
    multipliers = {'s': 1, 'm': 60, 'h': 3600, 'd': 86400, 'w': 604800}
    return n * multipliers[unit]


def parse_time(s):
    """Parse time string to epoch timestamp"""
    if s is None:
        return None
    if s == 'now':
        return int(datetime.now().timestamp())
    try:
        return int(s)
    except ValueError:
        pass
    for fmt in ["%Y-%m-%d", "%Y-%m-%d %H:%M", "%Y-%m-%d %H:%M:%S", "%Y-%m-%dT%H:%M:%S"]:
        try:
            return int(datetime.strptime(s, fmt).timestamp())
        except ValueError:
            continue
    raise ValueError(f"Invalid time: {s}")


def _curl(cmd):
    """Run curl and return parsed JSON or error dict"""
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        # Try to parse error body from Prometheus
        try:
            data = json.loads(result.stdout)
            if data.get('error'):
                return {"status": "error", "error": data['error']}
        except (json.JSONDecodeError, TypeError):
            pass
        return {"status": "error", "error": result.stderr.strip() or f"curl exit code {result.returncode}"}
    try:
        return json.loads(result.stdout)
    except json.JSONDecodeError as e:
        return {"status": "error", "error": f"JSON parse error: {e}", "raw": result.stdout[:500]}


def run_query(query, start=None, end=None, step="5m"):
    """Execute Prometheus query via curl"""
    if start is not None and end is not None:
        endpoint = f"{PROM_URL}/api/v1/query_range"
        cmd = [
            "curl", "--max-time", CURL_TIMEOUT, "-sS", endpoint,
            "--data-urlencode", f"query={query}",
            "--data-urlencode", f"start={start}",
            "--data-urlencode", f"end={end}",
            "--data-urlencode", f"step={step}"
        ]
    else:
        endpoint = f"{PROM_URL}/api/v1/query"
        cmd = ["curl", "--max-time", CURL_TIMEOUT, "-sS", endpoint, "--data-urlencode", f"query={query}"]
    return _curl(cmd)


def _safe_float(val):
    """Convert to float, returning None for NaN/Inf/invalid"""
    try:
        f = float(val)
        if f != f or f == float('inf') or f == float('-inf'):
            return None
        return f
    except (ValueError, TypeError):
        return None


def format_output(data, query=None):
    """Format output as AI-friendly JSON"""
    if data.get('status') != 'success':
        return {"error": data.get('error', data.get('errorType', 'Unknown'))}

    result = data.get('data', {})
    result_type = result.get('resultType', '')
    results = result.get('result', [])

    output = {
        "type": result_type,
        "count": len(results)
    }
    if query:
        output["query"] = query

    if result_type == 'vector':
        output["data"] = []
        for r in results:
            metric = r.get('metric', {})
            ts, val = r.get('value', [0, '0'])
            output["data"].append({"labels": metric, "value": _safe_float(val)})

    elif result_type == 'matrix':
        output["data"] = []
        for r in results:
            metric = r.get('metric', {})
            values = r.get('values', [])
            nums = [f for v in values if (f := _safe_float(v[1])) is not None]

            item = {"labels": metric, "samples": len(nums)}
            if nums:
                item["min"] = round(min(nums), 4)
                item["max"] = round(max(nums), 4)
                item["avg"] = round(sum(nums) / len(nums), 4)
                item["range"] = [
                    datetime.fromtimestamp(values[0][0], tz=timezone.utc).isoformat(),
                    datetime.fromtimestamp(values[-1][0], tz=timezone.utc).isoformat()
                ]
                item["values"] = [
                    [datetime.fromtimestamp(v[0], tz=timezone.utc).isoformat(), _safe_float(v[1])]
                    for v in values
                ]
            output["data"].append(item)

    elif result_type == 'scalar':
        ts, val = result.get('result', [0, '0'])
        output["value"] = _safe_float(val)

    return output


def get_label_values(label):
    """Get values for a label"""
    if not re.fullmatch(r'[a-zA-Z_][a-zA-Z0-9_]*', label):
        return {"error": f"Invalid label name: {label}"}
    cmd = ["curl", "--max-time", CURL_TIMEOUT, "-sS", f"{PROM_URL}/api/v1/label/{label}/values"]
    data = _curl(cmd)
    if data.get('status') == 'success':
        return {"label": label, "count": len(data.get('data', [])), "values": sorted(data.get('data', []))}
    return {"error": data.get('error', data.get('errorType', 'Unknown error'))}


def get_labels(metric):
    """Get labels for a metric"""
    cmd = ["curl", "--max-time", CURL_TIMEOUT, "-sS", f"{PROM_URL}/api/v1/labels", "--data-urlencode", f"match[]={metric}"]
    data = _curl(cmd)
    if data.get('status') == 'success':
        return {"metric": metric, "labels": sorted(data.get('data', []))}
    return {"error": data.get('error', data.get('errorType', 'Unknown error'))}


def get_metrics(pattern=None):
    """List metrics matching pattern"""
    cmd = ["curl", "--max-time", CURL_TIMEOUT, "-sS", f"{PROM_URL}/api/v1/label/__name__/values"]
    data = _curl(cmd)
    if data.get('status') != 'success':
        return {"error": data.get('error', data.get('errorType', 'Unknown error'))}
    metrics = data.get('data', [])
    if pattern:
        try:
            metrics = [m for m in metrics if re.search(pattern, m, re.IGNORECASE)]
        except re.error as e:
            return {"error": f"invalid regex pattern: {e}"}
    return {"pattern": pattern, "count": len(metrics), "metrics": sorted(metrics)}


def _error_json(msg):
    """Print error as JSON and exit"""
    print(json.dumps({"error": msg}, indent=2))
    sys.exit(1)


def main():
    global PROM_URL

    parser = argparse.ArgumentParser(
        description="Prometheus query helper (AI-optimized JSON output)",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=f"Default URL: {DEFAULT_URL}"
    )
    parser.add_argument('query', nargs='?', help='PromQL query')
    parser.add_argument('-f', '--query-file', metavar='FILE', help='Read PromQL query from file (overrides positional query)')
    parser.add_argument('--url', help='Prometheus URL (overrides PROM_URL env)')
    parser.add_argument('-r', '--range', dest='duration', help='Time range (e.g., 1h, 24h, 7d)')
    parser.add_argument('-s', '--step', default='5m', help='Query step (default: 5m)')
    parser.add_argument('--start', help='Start time (YYYY-MM-DD or epoch)')
    parser.add_argument('--end', help='End time (YYYY-MM-DD or epoch)')
    parser.add_argument('--labels', metavar='METRIC', help='Show labels for metric')
    parser.add_argument('--values', metavar='LABEL', help='Show values for label')
    parser.add_argument('--metrics', nargs='?', const='', metavar='PATTERN', help='List metrics')

    args = parser.parse_args()

    if args.query_file:
        try:
            with open(args.query_file) as fh:
                args.query = fh.read().strip()
        except (IOError, OSError, UnicodeDecodeError) as e:
            _error_json(f"Cannot read query file: {e}")
        if not args.query:
            _error_json(f"Query file is empty: {args.query_file}")

    # Set URL: --url flag > PROM_URL env > default
    if args.url:
        PROM_URL = args.url
    else:
        PROM_URL = os.environ.get("PROM_URL", DEFAULT_URL)

    # List metrics
    if args.metrics is not None:
        print(json.dumps(get_metrics(args.metrics if args.metrics else None), indent=2, allow_nan=False))
        return

    # Labels for metric
    if args.labels:
        print(json.dumps(get_labels(args.labels), indent=2, allow_nan=False))
        return

    # Label values
    if args.values:
        print(json.dumps(get_label_values(args.values), indent=2, allow_nan=False))
        return

    # Query required for execution
    if not args.query:
        _error_json("No query provided. Use positional arg or --query-file / -f")

    # Validate start/end pair
    if (args.start and not args.end) or (args.end and not args.start):
        _error_json("--start and --end must be provided together")

    # Time range
    try:
        start = None
        end = None
        if args.start and args.end:
            start = parse_time(args.start)
            end = parse_time(args.end)
        elif args.duration:
            end = int(datetime.now().timestamp())
            start = end - parse_duration(args.duration)
    except ValueError as e:
        _error_json(str(e))

    if start is not None and end is not None and end < start:
        _error_json("--end must be after --start")

    # Execute and format
    data = run_query(args.query, start, end, args.step)
    output = format_output(data, args.query)
    print(json.dumps(output, indent=2, allow_nan=False))


if __name__ == '__main__':
    main()
