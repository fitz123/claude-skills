#!/usr/bin/env bash
set -euo pipefail

# Update a Gitea PR description/title via API
# Reads credentials from ~/.config/tea/config.yml

usage() {
  echo "Usage: gitea-pr-update --repo owner/repo --index N --body-file /path [--title \"text\"]"
  exit 1
}

REPO="" INDEX="" BODY_FILE="" TITLE=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo)      REPO="$2"; shift 2 ;;
    --index)     INDEX="$2"; shift 2 ;;
    --body-file) BODY_FILE="$2"; shift 2 ;;
    --title)     TITLE="$2"; shift 2 ;;
    *)           echo "Unknown flag: $1"; usage ;;
  esac
done

[[ -z "$REPO" || -z "$INDEX" ]] && usage
[[ -z "$BODY_FILE" && -z "$TITLE" ]] && { echo "Error: provide --body-file and/or --title"; exit 1; }
[[ -n "$BODY_FILE" && ! -f "$BODY_FILE" ]] && { echo "Error: file not found: $BODY_FILE"; exit 1; }

TEA_CONFIG="${HOME}/.config/tea/config.yml"
[[ ! -f "$TEA_CONFIG" ]] && { echo "Error: tea config not found at $TEA_CONFIG"; exit 1; }

# Parse tea config safely via python reading the file directly
read -r GITEA_URL GITEA_TOKEN <<< "$(python3 - "$TEA_CONFIG" <<'PYEOF'
import sys
try:
    import yaml
    with open(sys.argv[1]) as f:
        cfg = yaml.safe_load(f)
except ImportError:
    import re
    with open(sys.argv[1]) as f:
        text = f.read()
    url_m = re.search(r'url:\s*(\S+)', text)
    token_m = re.search(r'token:\s*(\S+)', text)
    if not url_m or not token_m:
        print('Error: could not find url/token in tea config', file=sys.stderr)
        sys.exit(1)
    print(url_m.group(1), token_m.group(1))
    sys.exit(0)
login = cfg['logins'][0]
print(login['url'], login['token'])
PYEOF
)"

[[ -z "$GITEA_URL" || -z "$GITEA_TOKEN" ]] && { echo "Error: could not parse tea config"; exit 1; }

# Build JSON payload safely — python reads files directly, no shell interpolation
TMPJSON=$(mktemp /tmp/gitea-pr-update-XXXXXXXX.json)
trap 'rm -f "$TMPJSON"' EXIT

python3 - "$BODY_FILE" "$TITLE" <<'PYEOF' > "$TMPJSON"
import json, sys
data = {}
body_file = sys.argv[1]
title = sys.argv[2]
if body_file:
    with open(body_file) as f:
        data['body'] = f.read()
if title:
    data['title'] = title
print(json.dumps(data))
PYEOF

# Make API call
RESPONSE=$(curl --max-time 10 -s -w "\n%{http_code}" -X PATCH \
  "${GITEA_URL}/api/v1/repos/${REPO}/pulls/${INDEX}" \
  -H "Content-Type: application/json" \
  -H "Authorization: token ${GITEA_TOKEN}" \
  -d @"$TMPJSON")

HTTP_CODE=$(echo "$RESPONSE" | tail -1)
BODY=$(echo "$RESPONSE" | sed '$d')

if [[ "$HTTP_CODE" -ge 200 && "$HTTP_CODE" -lt 300 ]]; then
  PR_URL=$(python3 -c "import json,sys; d=json.loads(sys.stdin.read()); print(d.get('html_url', 'PR updated (no URL in response)'))" <<< "$BODY")
  echo "Updated: $PR_URL"
else
  echo "Error (HTTP $HTTP_CODE): $BODY" >&2
  exit 1
fi
