#!/usr/bin/env bash
# Fetch a YouTrack issue with description and all comments
# Usage: yt-view DVPS-1234
set -euo pipefail

ISSUE_ID="${1:?Usage: yt-view ISSUE-ID}"
BASE="https://ordercapital.myjetbrains.com/youtrack/api"
TOKEN=$(printenv YOUTRACK_TOKEN)
FIELDS="idReadable,summary,description,created,updated,resolved,customFields(name,value(name)),tags(name),comments(text,created,author(login)),links(issues(idReadable,summary),linkType(name,sourceToTarget,targetToSource),direction)"

curl -s -k -H "Accept: application/json" \
  -H "Authorization: Bearer $TOKEN" \
  "${BASE}/issues/${ISSUE_ID}?fields=${FIELDS}" \
| python3 -c "
import json, sys
from datetime import datetime, timezone

d = json.load(sys.stdin)
if 'error' in d or '\$type' not in d:
    print(json.dumps(d, indent=2))
    sys.exit(1)

def ts(ms):
    return datetime.fromtimestamp(ms/1000, tz=timezone.utc).strftime('%Y-%m-%d %H:%M UTC') if ms else 'n/a'

# Extract custom fields
cf = {}
for f in d.get('customFields', []):
    v = f.get('value')
    if isinstance(v, dict):
        cf[f['name']] = v.get('name', '?')
    elif isinstance(v, list):
        cf[f['name']] = ', '.join(x.get('name','?') for x in v if isinstance(x, dict))
    elif v is not None:
        cf[f['name']] = str(v)

state = cf.get('State', '?')
priority = cf.get('Priority', '?')
issue_type = cf.get('Type', '')

print(f\"# {d['idReadable']}: {d['summary']}\")
type_str = f'  |  Type: {issue_type}' if issue_type else ''
print(f\"State: {state}  |  Priority: {priority}{type_str}\")
tags = ', '.join(t['name'] for t in d.get('tags', []))
if tags:
    print(f'Tags: {tags}')
print(f\"Created: {ts(d.get('created'))}  |  Updated: {ts(d.get('updated'))}  |  Resolved: {ts(d.get('resolved'))}\")
print()
print('## Description')
print(d.get('description') or '(empty)')

links = d.get('links', [])
link_groups = {}
for link in links:
    lt = link.get('linkType', {})
    direction = link.get('direction', 'BOTH')
    if direction == 'OUTWARD':
        label = lt.get('sourceToTarget', lt.get('name', '?'))
    elif direction == 'INWARD':
        label = lt.get('targetToSource', lt.get('name', '?'))
    else:
        label = lt.get('name', '?')
    issues = link.get('issues', [])
    if issues:
        link_groups.setdefault(label, []).extend(issues)
if link_groups:
    print('\n## Links')
    for label, linked in link_groups.items():
        ids = ', '.join(f\"{i.get('idReadable','?')} {i.get('summary','')}\" for i in linked)
        print(f'  {label}: {ids}')

comments = d.get('comments', [])
if comments:
    print(f'\n## Comments ({len(comments)})')
    for i, c in enumerate(comments, 1):
        author = c.get('author', {}).get('login', '?')
        print(f'\n### [{i}/{len(comments)}] {author} — {ts(c.get(\"created\"))}')
        print(c.get('text', ''))
"
