#!/usr/bin/env bash
# Search YouTrack issues
# Usage: yt-search "query"
#    or: yt-search "query" [--top N] [--fields FIELDS]
#
# Examples:
#   yt-search "Assignee:me #Unresolved"
#   yt-search "subtask of: DVPS-6888 #Unresolved"
#   yt-search "Assignee:gmalashikhin #Unresolved" --top 50
#   yt-search "tag: Operations updated: {Last week}"
#   yt-search "(Assignee:me or reporter:me) and updated: Today"
set -euo pipefail

QUERY="${1:?Usage: yt-search \"query\" [--top N] [--fields FIELDS]}"
shift

TOP=100
FIELDS="idReadable,summary,customFields(name,value(name)),resolved,tags(name)"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --top) [[ $# -ge 2 ]] || { echo "Error: --top requires a value" >&2; exit 1; }; TOP="$2"; shift 2 ;;
    --fields) [[ $# -ge 2 ]] || { echo "Error: --fields requires a value" >&2; exit 1; }; FIELDS="$2"; shift 2 ;;
    *) echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

BASE="https://ordercapital.myjetbrains.com/youtrack/api"
TOKEN=$(printenv YOUTRACK_TOKEN)

# URL-encode the query
ENCODED_QUERY=$(python3 -c "import urllib.parse, sys; print(urllib.parse.quote(sys.argv[1]))" "$QUERY")

RESULT=$(curl -s -k -m 30 -H "Accept: application/json" \
  -H "Authorization: Bearer $TOKEN" \
  "${BASE}/issues?fields=${FIELDS}&query=${ENCODED_QUERY}&\$top=${TOP}")

echo "$RESULT" | python3 -c "
import json, sys

raw = sys.stdin.read()
try:
    data = json.loads(raw)
except json.JSONDecodeError:
    print(f'Error: non-JSON response: {raw[:200]}', file=sys.stderr)
    sys.exit(1)
if isinstance(data, dict) and ('error' in data or 'error_description' in data):
    print(f\"Error: {data.get('error', data.get('error_description', json.dumps(data)))}\")
    sys.exit(1)

if not isinstance(data, list):
    print(json.dumps(data, indent=2))
    sys.exit(1)

if not data:
    print('No issues found.')
    sys.exit(0)

print(f'Found {len(data)} issue(s):')
print()

for issue in data:
    iid = issue.get('idReadable', '?')
    summary = issue.get('summary', '?')
    resolved = issue.get('resolved')

    # Extract custom fields
    state = '?'
    priority = '?'
    assignees = []
    issue_type = ''
    for cf in issue.get('customFields', []):
        name = cf.get('name', '')
        val = cf.get('value')
        if name == 'State' and isinstance(val, dict):
            state = val.get('name', '?')
        elif name == 'Priority' and isinstance(val, dict):
            priority = val.get('name', '?')
        elif name == 'Type' and isinstance(val, dict):
            issue_type = val.get('name', '')
        elif name == 'Assignee' and isinstance(val, list):
            assignees = [v.get('name', '?') for v in val if isinstance(v, dict)]

    tags = [t.get('name', '?') for t in issue.get('tags', [])]

    status_icon = '✓' if resolved else '○'
    assignee_list = ', '.join(assignees)
    assignee_str = f'  [{assignee_list}]' if assignees else ''
    tag_list = ','.join(tags)
    tag_str = f'  tags:{tag_list}' if tags else ''

    type_str = f'  type:{issue_type}' if issue_type and issue_type != 'Task' else ''

    print(f'{status_icon} {iid} [{priority}] [{state}] {summary}{assignee_str}{tag_str}{type_str}')
"
