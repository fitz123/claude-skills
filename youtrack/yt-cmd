#!/usr/bin/env bash
# Execute YouTrack commands API (assign, unassign, tag, link, state, priority, etc.)
# Usage: yt-cmd ISSUE-ID "command query"
#    or: yt-cmd ISSUE-ID,ISSUE-ID2 "command query"  (multiple issues)
#
# Examples:
#   yt-cmd DVPS-1234 "Assignee gmalashikhin"
#   yt-cmd DVPS-1234 "remove Assignee alugovoi"
#   yt-cmd DVPS-1234 "subtask of DVPS-6888"
#   yt-cmd DVPS-1234 "tag Operations"
#   yt-cmd DVPS-1234 "untag Operations"
#   yt-cmd DVPS-1234 "state Reviewing"
#   yt-cmd DVPS-1234 "Priority P2"
#   yt-cmd DVPS-1234 "Assignee gmalashikhin subtask of DVPS-6888 remove Assignee alugovoi"
#   yt-cmd DVPS-1234,DVPS-5678 "tag Operations Priority P3"
set -euo pipefail

ISSUES_RAW="${1:?Usage: yt-cmd ISSUE-ID[,ISSUE-ID2,...] \"command query\"}"
QUERY="${2:?Usage: yt-cmd ISSUE-ID[,ISSUE-ID2,...] \"command query\"}"
BASE="https://ordercapital.myjetbrains.com/youtrack/api"
TOKEN=$(printenv YOUTRACK_TOKEN)

# Build issues JSON array from comma-separated list
IFS=',' read -ra ISSUE_LIST <<< "$ISSUES_RAW"
ISSUES_JSON="["
for i in "${!ISSUE_LIST[@]}"; do
  if [[ $i -gt 0 ]]; then
    ISSUES_JSON+=","
  fi
  ISSUES_JSON+="{\"idReadable\":\"${ISSUE_LIST[$i]}\"}"
done
ISSUES_JSON+="]"

TMPFILE=$(mktemp "/tmp/yt-cmd-XXXXXX.json")
trap "rm -f '$TMPFILE'" EXIT

python3 -c "
import json, sys
with open(sys.argv[1], 'w') as f:
    json.dump({'query': sys.argv[2], 'issues': json.loads(sys.argv[3])}, f)
" "$TMPFILE" "$QUERY" "$ISSUES_JSON"

RESULT=$(curl -s -k -m 30 -X POST \
  -H "Accept: application/json" \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer $TOKEN" \
  "${BASE}/commands" \
  -d @"$TMPFILE")

# Empty {} means success
if [[ "$RESULT" == "{}" ]] || [[ -z "$RESULT" ]]; then
  echo "OK: ${ISSUES_RAW} <- ${QUERY}"
else
  # Check for error
  echo "$RESULT" | python3 -c "
import json, sys
raw = sys.stdin.read()
try:
    d = json.loads(raw)
except json.JSONDecodeError:
    print(f'Error: non-JSON response: {raw[:200]}', file=sys.stderr)
    sys.exit(1)
if 'error' in d or 'error_description' in d:
    print(f\"Error: {d.get('error', d.get('error_description', json.dumps(d)))}\")
    sys.exit(1)
else:
    print(json.dumps(d, indent=2))
"
fi
